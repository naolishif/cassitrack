# ── CassiTrack — Local Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your local values.
# NEVER commit .env to git — it is already in .gitignore.
#
# How to load in IntelliJ:
#   Run > Edit Configurations > select CassitrackApplication
#   > Modify options > Environment variables > paste each line as KEY=VALUE
# ──────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/cassitrack
SPRING_DATASOURCE_USERNAME=cassitrack
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# ── Redis ─────────────────────────────────────────────────────────────────
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your_redis_password_here

# ── JWT (use any long random string — min 32 chars) ───────────────────────
JWT_SECRET=replace-with-a-random-256bit-secret-string

# ── InfluxDB ──────────────────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influxdb_token_here
INFLUX_ORG=unicas
INFLUX_BUCKET=vehicle_telemetry

# ── SSE internal API token (must match CASSITRACK_API_TOKEN in OmniMove) ──
SSE_API_TOKEN=your_sse_api_token_here

# ── MQTT ──────────────────────────────────────────────────────────────────
MQTT_BROKER_URL=tcp://localhost:1883
# Set these when the Mosquitto broker has password_file authentication enabled
MQTT_USERNAME=cassitrack
MQTT_PASSWORD=your_mqtt_password_here

# ── External APIs (optional — app degrades gracefully if not set) ─────────
WEATHER_API_KEY=your_openweathermap_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here