# ── OmniMove — Local Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your local values.
# NEVER commit .env to git — it is already in .gitignore.
#
# How to load in IntelliJ:
#   Run > Edit Configurations > select OmnimoveApplication
#   > Modify options > Environment variables > paste each line as KEY=VALUE
# ──────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/omnimovedb
SPRING_DATASOURCE_USERNAME=omnimove
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# ── JWT (use any long random string — min 32 chars) ───────────────────────
JWT_SECRET=replace-with-a-random-256bit-secret-string

# ── InfluxDB ──────────────────────────────────────────────────────────────
INFLUX_URL=http://localhost:8087
INFLUX_TOKEN=your_influxdb_token_here

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────
# Generate a Gmail App Password at: myaccount.google.com/apppasswords
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_16char_gmail_app_password

# ── CassiTrack connection (must match SSE_API_TOKEN in CassiTrack) ────────
CASSITRACK_URL=http://localhost:8080/api/v1
CASSITRACK_API_TOKEN=your_sse_api_token_here
CASSITRACK_NETEX_URL=http://localhost:8080/api/static/netex

# ── App base URL (used in email links) ───────────────────────────────────
APP_BASE_URL=http://localhost:8081

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# ── External APIs (optional — app degrades gracefully if not set) ─────────
WEATHER_API_KEY=your_openweathermap_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here